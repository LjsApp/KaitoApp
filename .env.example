# ─── Supabase ────────────────────────────────────────────────────────────────
# Ambil dari Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx
SUPABASE_PROJECT_ID=your-project-id

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx
VITE_SUPABASE_PROJECT_ID=your-project-id

# ─── Service Role Key (RAHASIA — hanya di server/Vercel, jangan publish) ──────
# Ambil dari: Supabase Dashboard > Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Admin Session ────────────────────────────────────────────────────────────
# String random minimal 32 karakter untuk keamanan
ADMIN_SESSION_SECRET=random-string-min-32-chars-ganti-ini
